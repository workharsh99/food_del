# Frontend env (copy to `app/.env`)
# If you keep these unset, the app will use:
# - API: `/api` (proxied to backend in dev via Vite)
# - Socket: same-origin `/socket.io` (proxied to backend in dev via Vite)
VITE_API_URL=
VITE_SOCKET_URL=

# Google OAuth Client ID (get from https://console.cloud.google.com/apis/credentials)
# Required for Google Sign-In functionality
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

